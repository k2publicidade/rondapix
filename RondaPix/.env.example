# ==========================================
# RONDA ONLINE — Environment Variables
# ==========================================
# Copie para .env.local e preencha os valores

# --- Banco de dados ---
DATABASE_URL="postgresql://ronda:ronda@localhost:5432/ronda_online"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth (JWT) ---
JWT_SECRET="change-me-in-production-32-chars-min"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_EXPIRES_IN="30d"

# --- API ---
API_PORT=3001
API_URL="http://localhost:3001"

# --- Web ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_APP_NAME="Ronda Online"

# --- Worker ---
WORKER_CONCURRENCY=5

# --- Game Engine ---
HOUSE_EDGE=0.05
MIN_BET=10
MAX_BET=10000
BETTING_WINDOW_SECONDS=30
REVEAL_INTERVAL_MS=800

# --- Admin ---
ADMIN_PORT=3002
ADMIN_SECRET="change-me-admin-secret"

# --- Fairness ---
MASTER_SERVER_SEED="change-me-server-seed-secret"
