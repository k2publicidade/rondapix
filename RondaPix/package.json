{
  "name": "ronda-online",
  "version": "0.0.1",
  "private": true,
  "description": "Ronda Online – jogo de cartas multiplayer com apostas virtuais",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .prettierignore",
    "test": "turbo run test",
    "test:ci": "turbo run test --concurrency=1",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck",
    "db:generate": "cd prisma && pnpm prisma generate",
    "db:migrate": "cd prisma && pnpm prisma migrate dev",
    "db:seed": "cd prisma && pnpm prisma db seed",
    "db:studio": "cd prisma && pnpm prisma studio",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.3"
}
