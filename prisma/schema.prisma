// ================================================================
// Ronda Online — Prisma Schema
// ================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------
// Usuários e Perfis
// ----------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  profile    Profile?
  wallet     Wallet?
  rooms      Room[]         @relation("RoomHost")
  roomMemberships RoomMember[]
  bets       Bet[]
  auditLogs  AuditLog[]

  @@map("users")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  username    String   @unique
  avatarUrl   String?  @map("avatar_url")
  totalRounds Int      @default(0) @map("total_rounds")
  wins        Int      @default(0)
  losses      Int      @default(0)
  totalWagered Decimal @default(0) @map("total_wagered") @db.Decimal(18, 2)
  totalWon    Decimal  @default(0) @map("total_won") @db.Decimal(18, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaderboard  Leaderboard?

  @@map("profiles")
}

// ----------------------------------------------------------------
// Wallet e Transações
// ----------------------------------------------------------------

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  balance       Decimal  @default(0) @db.Decimal(18, 2)
  lockedBalance Decimal  @default(0) @map("locked_balance") @db.Decimal(18, 2)
  currency      String   @default("COINS")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  version       Int      @default(0) // optimistic locking

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id            String            @id @default(cuid())
  walletId      String            @map("wallet_id")
  userId        String            @map("user_id")
  type          TransactionType
  amount        Decimal           @db.Decimal(18, 2)
  balanceBefore Decimal           @map("balance_before") @db.Decimal(18, 2)
  balanceAfter  Decimal           @map("balance_after") @db.Decimal(18, 2)
  status        TransactionStatus @default(COMPLETED)
  referenceId   String?           @map("reference_id")
  description   String            @default("")
  idempotencyKey String?          @unique @map("idempotency_key")
  createdAt     DateTime          @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([userId])
  @@index([referenceId])
  @@map("wallet_transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_PLACED
  BET_WON
  BET_REFUNDED
  BONUS
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

// ----------------------------------------------------------------
// Salas
// ----------------------------------------------------------------

model Room {
  id           String         @id @default(cuid())
  name         String
  code         String         @unique // código curto para entrar na sala
  hostId       String         @map("host_id")
  status       RoomStatus     @default(WAITING)
  visibility   RoomVisibility @default(PUBLIC)
  maxPlayers   Int            @default(8) @map("max_players")
  minBet       Decimal        @default(10) @map("min_bet") @db.Decimal(18, 2)
  maxBet       Decimal        @default(10000) @map("max_bet") @db.Decimal(18, 2)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  closedAt     DateTime?      @map("closed_at")

  host         User         @relation("RoomHost", fields: [hostId], references: [id])
  members      RoomMember[]
  rounds       Round[]
  chatMessages ChatMessage[]

  @@index([status, visibility])
  @@map("rooms")
}

model RoomMember {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  playerId  String   @map("player_id")
  isHost    Boolean  @default(false) @map("is_host")
  seatIndex Int?     @map("seat_index")
  joinedAt  DateTime @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  room   Room @relation(fields: [roomId], references: [id])
  player User @relation(fields: [playerId], references: [id])

  @@unique([roomId, playerId])
  @@map("room_members")
}

enum RoomStatus {
  WAITING
  IN_PROGRESS
  FINISHED
  CLOSED
}

enum RoomVisibility {
  PUBLIC
  PRIVATE
}

// ----------------------------------------------------------------
// Rodadas
// ----------------------------------------------------------------

model Round {
  id              String      @id @default(cuid())
  roomId          String      @map("room_id")
  status          RoundStatus @default(WAITING_FOR_PLAYERS)
  sequence        Int         @default(0)
  nonce           Int         @default(1)

  // Par de cartas
  sideACardId     String?     @map("side_a_card_id")
  sideBCardId     String?     @map("side_b_card_id")

  // Cortador
  cutterId        String?     @map("cutter_id")
  cutterSide      CardSide?   @map("cutter_side")

  // Resultado
  winnerCardId    String?     @map("winner_card_id")
  winnerSide      CardSide?   @map("winner_side")

  // Seeds de fairness
  serverSeedHash  String?     @map("server_seed_hash")
  serverSeed      String?     @map("server_seed") // revelado após o fim
  clientSeed      String?     @map("client_seed")

  // Financeiro
  totalPool       Decimal     @default(0) @map("total_pool") @db.Decimal(18, 2)
  houseEdge       Decimal     @default(0.05) @map("house_edge") @db.Decimal(5, 4)

  startedAt       DateTime?   @map("started_at")
  bettingEndsAt   DateTime?   @map("betting_ends_at")
  endedAt         DateTime?   @map("ended_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  room           Room           @relation(fields: [roomId], references: [id])
  bets           Bet[]
  deckSnapshot   DeckSnapshot?
  replay         Replay?
  fairnessProof  FairnessProof?
  targets        RoundTarget[]

  @@index([roomId, status])
  @@map("rounds")
}

model RoundTarget {
  id       String   @id @default(cuid())
  roundId  String   @map("round_id")
  side     CardSide
  cardId   String   @map("card_id")
  hitIndex Int?     @map("hit_index") // índice no deck onde foi encontrada

  round Round @relation(fields: [roundId], references: [id])

  @@unique([roundId, side])
  @@map("round_targets")
}

enum RoundStatus {
  WAITING_FOR_PLAYERS
  ASSIGNING_CUTTER
  PAIR_REVEALED
  BETTING_OPEN
  BETTING_LOCKED
  SHUFFLING
  RUNNING_DECK
  ROUND_SETTLED
  ROUND_CANCELLED
}

enum CardSide {
  A
  B
}

// ----------------------------------------------------------------
// Apostas
// ----------------------------------------------------------------

model Bet {
  id             String    @id @default(cuid())
  roundId        String    @map("round_id")
  playerId       String    @map("player_id")
  side           CardSide
  amount         Decimal   @db.Decimal(18, 2)
  status         BetStatus @default(PENDING)
  payout         Decimal?  @db.Decimal(18, 2)
  idempotencyKey String    @unique @map("idempotency_key")
  placedAt       DateTime  @default(now()) @map("placed_at")
  settledAt      DateTime? @map("settled_at")

  round  Round @relation(fields: [roundId], references: [id])
  player User  @relation(fields: [playerId], references: [id])

  @@unique([roundId, playerId]) // 1 aposta por jogador por rodada
  @@index([playerId])
  @@map("bets")
}

enum BetStatus {
  PENDING
  WON
  LOST
  REFUNDED
}

// ----------------------------------------------------------------
// Deck e Replay
// ----------------------------------------------------------------

model DeckSnapshot {
  id           String   @id @default(cuid())
  roundId      String   @unique @map("round_id")
  orderedCards String[] @map("ordered_cards") // IDs das cartas na ordem do shuffle
  createdAt    DateTime @default(now()) @map("created_at")

  round Round @relation(fields: [roundId], references: [id])

  @@map("deck_snapshots")
}

model Replay {
  id        String   @id @default(cuid())
  roundId   String   @unique @map("round_id")
  events    Json     // Array de RoundEvent serializado
  createdAt DateTime @default(now()) @map("created_at")

  round Round @relation(fields: [roundId], references: [id])

  @@map("replays")
}

model FairnessProof {
  id                   String   @id @default(cuid())
  roundId              String   @unique @map("round_id")
  serverSeedHash       String   @map("server_seed_hash")
  serverSeed           String?  @map("server_seed")
  clientSeed           String   @map("client_seed")
  nonce                Int
  shuffledDeckSnapshot String[] @map("shuffled_deck_snapshot")
  algorithm            String   @default("HMAC-SHA256 Fisher-Yates")
  version              String   @default("1.0")
  verifiable           Boolean  @default(false)
  createdAt            DateTime @default(now()) @map("created_at")
  revealedAt           DateTime? @map("revealed_at")

  round Round @relation(fields: [roundId], references: [id])

  @@map("fairness_proofs")
}

// ----------------------------------------------------------------
// Chat
// ----------------------------------------------------------------

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  playerId  String   @map("player_id")
  username  String   // desnormalizado para performance
  content   String
  sentAt    DateTime @default(now()) @map("sent_at")

  room Room @relation(fields: [roomId], references: [id])

  @@index([roomId, sentAt])
  @@map("chat_messages")
}

// ----------------------------------------------------------------
// Leaderboard e Auditoria
// ----------------------------------------------------------------

model Leaderboard {
  id           String   @id @default(cuid())
  profileId    String   @unique @map("profile_id")
  score        Decimal  @default(0) @db.Decimal(18, 2)
  rank         Int?
  period       String   @default("ALL_TIME") // ALL_TIME, WEEKLY, MONTHLY
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id])

  @@index([period, score(sort: Desc)])
  @@map("leaderboards")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String   @map("entity_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
